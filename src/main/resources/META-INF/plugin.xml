<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.jpmand.idea.plugin.gitea</id>
    <name>Gitea</name>
    <vendor>JpMand</vendor>
    <version>0.0.1</version>
    <idea-version since-build="253"/>
    <category>Version Controls</category>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <resource-bundle>messages.GiteaBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.github.jpmand.idea.plugin.gitea.authentication.account.GitePersistentAccounts"/>
        <applicationService serviceInterface="com.github.jpmand.idea.plugin.gitea.authentication.account.GiteaAccountManager"
                            serviceImplementation="com.github.jpmand.idea.plugin.gitea.authentication.account.PersistentGiteaAccountManager"/>
        <applicationService serviceInterface="com.github.jpmand.idea.plugin.gitea.api.GiteaApiManager"
                            serviceImplementation="com.github.jpmand.idea.plugin.gitea.api.GiteaApiManagerImpl"/>
        <projectService serviceInterface="com.github.jpmand.idea.plugin.gitea.GiteaRepositoriesManager"
                        serviceImplementation="com.github.jpmand.idea.plugin.gitea.GiteaRepositoriesManagerImpl"/>
        <!--suppress PluginXmlI18n Name Gitea should not be translated-->
        <projectConfigurable parentId="project.propVCSSupport.Mappings" groupWeight="-600"
                             instance="com.github.jpmand.idea.plugin.gitea.ui.GiteaSettingsConfigurable"
                             displayName="Gitea"/>
        <!--suppress PluginXmlI18n Name Gitea should not be translated-->
        <toolWindow id="Gitea"
                    anchor="bottom"
                    icon="/images/giteaLogo.svg"
                    factoryClass="com.github.jpmand.idea.plugin.gitea.ui.toolwindow.GiteaPullRequestsToolWindowFactory"/>
    </extensions>
    <extensions defaultExtensionNs="Git4Idea">
        <GitHttpAuthDataProvider id="Gitea.Silent"
                                 implementation="com.github.jpmand.idea.plugin.gitea.authentication.extensions.GiteaSilentHttpAuthDataProvider" />
        <GitHttpAuthDataProvider id="Gitea"
                                 implementation="com.github.jpmand.idea.plugin.gitea.authentication.extensions.GiteaHttpAuthDataProvider"/>
    </extensions>

    <actions>
        <!--suppress PluginXmlCapitalization -->
        <action id="Gitea.Open.Settings"
                class="com.github.jpmand.idea.plugin.gitea.GiteaOpenSettingsAction"
                icon="/images/giteaLogo.svg">
            <!--suppress PluginXmlCapitalization -->
            <override-text place="MainMenu"/>
            <!--suppress PluginXmlCapitalization -->
            <override-text place="popup@GoToAction"/>
            <synonym key="action.Gitea.Add.Account.synonym"/>
        </action>
    </actions>
</idea-plugin>
